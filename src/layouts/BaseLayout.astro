---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'DUC Essen - Deutscher Unterwasserclub Essen e.V.',
  description = 'DUC Essen - Dein Verein für Tauchen, Apnoe, Freediving und Flossenschwimmen in Essen. Training Di 20:00 & Do 20:15 im Stadtbad Nord-Ost. Kostenloses Probetraining!',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = 'https://duc-essen.de/wp-content/uploads/2024/02/Home-1-b.jpg';
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <!-- SEO Meta Tags -->
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="Tauchverein Essen, DUC Essen, Apnoe Essen, Freediving Essen, Flossenschwimmen, Unterwasserclub, Tauchen lernen Essen, VDST"
    />
    <meta name="author" content="Deutscher Unterwasserclub Essen e.V." />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="Tauchen, Apnoe, Freediving und Flossenschwimmen in Essen. Kostenloses Probetraining jeden Dienstag und Donnerstag!" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="DUC Essen" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content="Tauchen, Apnoe, Freediving und Flossenschwimmen in Essen. Kostenloses Probetraining!" />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured Data / JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'SportsClub',
      name: 'Deutscher Unterwasserclub Essen e.V.',
      alternateName: 'DUC Essen',
      url: 'https://duc-essen.de',
      logo: 'https://duc-essen.de/wp-content/uploads/2024/02/Home-1-b.jpg',
      description: 'Tauchverein in Essen für Tauchen, Apnoe, Freediving und Flossenschwimmen. Mitglied im VDST.',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Schonnebeckhöfe 60',
        addressLocality: 'Essen',
        postalCode: '45309',
        addressCountry: 'DE',
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: 51.4818,
        longitude: 7.0503,
      },
      telephone: '',
      email: 'info@duc-essen.de',
      sameAs: [],
      sport: ['Tauchen', 'Apnoe', 'Freediving', 'Flossenschwimmen'],
      memberOf: {
        '@type': 'Organization',
        name: 'Verband Deutscher Sporttaucher e.V.',
        alternateName: 'VDST',
      },
      openingHoursSpecification: [
        { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Tuesday', opens: '20:00', closes: '22:00' },
        { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Thursday', opens: '20:15', closes: '22:00' },
      ],
    })} />

    <!-- Favicon -->
    <link
      rel="icon"
      type="image/svg+xml"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><circle cx='50' cy='50' r='45' fill='%23004F9E'/><circle cx='50' cy='50' r='35' fill='%23FFD400'/><text x='50' y='62' font-size='32' font-weight='bold' text-anchor='middle' fill='%23004F9E'>DUC</text></svg>"
    />

    <!-- Theme Color -->
    <meta name="theme-color" content="#004F9E" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- Skip Link -->
    <a href="#main-content" class="skip-link">Zum Hauptinhalt springen</a>

    <!-- Animated Bubbles Background -->
    <div class="bubbles" aria-hidden="true">
      <div class="bubble"></div>
      <div class="bubble"></div>
      <div class="bubble"></div>
      <div class="bubble"></div>
      <div class="bubble"></div>
      <div class="bubble"></div>
      <div class="bubble"></div>
      <div class="bubble"></div>
      <div class="bubble"></div>
      <div class="bubble"></div>
    </div>

    <slot />

    <!-- Back to Top Button -->
    <button id="backToTop" class="back-to-top" aria-label="Nach oben scrollen">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="18 15 12 9 6 15"></polyline>
      </svg>
    </button>

    <script>
      // Current Year
      const yearEl = document.getElementById('currentYear');
      if (yearEl) yearEl.textContent = String(new Date().getFullYear());

      // Mobile Menu Toggle
      const menuToggle = document.getElementById('menuToggle');
      const navLinks = document.getElementById('navLinks');
      if (menuToggle && navLinks) {
        menuToggle.addEventListener('click', () => {
          navLinks.classList.toggle('active');
        });
        document.querySelectorAll('.nav-links a').forEach((link) => {
          link.addEventListener('click', () => navLinks.classList.remove('active'));
        });
      }

      // Navbar scroll effect
      const navbar = document.getElementById('navbar');
      const onScroll = () => {
        if (!navbar) return;
        if (window.scrollY > 100) navbar.classList.add('scrolled');
        else navbar.classList.remove('scrolled');
      };
      window.addEventListener('scroll', onScroll);
      onScroll();

      // Scroll animations (fade-in)
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) entry.target.classList.add('visible');
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
      );
      document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));

      // Smooth scroll for anchors
      document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
        anchor.addEventListener('click', (e) => {
          const href = (anchor as HTMLAnchorElement).getAttribute('href');
          if (!href || href === '#') return;
          const target = document.querySelector(href);
          if (target) {
            e.preventDefault();
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
      });

      // Active menu item on scroll
      const sections = document.querySelectorAll<HTMLElement>('section[id]');
      const navLinksAll = document.querySelectorAll<HTMLAnchorElement>('.nav-links a[href^="#"]');
      const updateActive = () => {
        const scrollPos = window.scrollY + 150;
        sections.forEach((section) => {
          const top = section.offsetTop;
          const h = section.offsetHeight;
          const id = section.getAttribute('id');
          if (scrollPos >= top && scrollPos < top + h) {
            navLinksAll.forEach((link) => {
              link.classList.remove('active');
              if (link.getAttribute('href') === '#' + id) link.classList.add('active');
            });
          }
        });
      };
      window.addEventListener('scroll', updateActive);
      updateActive();

      // Back to Top
      const backToTop = document.getElementById('backToTop');
      if (backToTop) {
        window.addEventListener('scroll', () => {
          if (window.scrollY > 500) backToTop.classList.add('visible');
          else backToTop.classList.remove('visible');
        });
        backToTop.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }
    </script>
  </body>
</html>
