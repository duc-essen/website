---
import { getCollection } from 'astro:content';

const stats = (await getCollection('stats')).sort(
  (a, b) => a.data.order - b.data.order
);
---
<section class="stats" id="verein">
  <div class="stats-grid">
    {stats.map((s) => (
      <div class="stat-item fade-in">
        <div class="stat-number">{s.data.wert}</div>
        <div class="stat-label">{s.data.label}</div>
      </div>
    ))}
  </div>
</section>
