---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import EventIcon from './icons/EventIcon.astro';

interface Props {
  section: CollectionEntry<'sections'>;
  isStandalone?: boolean;
}
const { section } = Astro.props;

const oeffentlich = (await getCollection('veranstaltungen')).sort(
  (a, b) => a.data.start.getTime() - b.data.start.getTime()
);
// Vergangene Termine kommen aus dem Loader bereits absteigend sortiert (neueste zuerst).
const vergangene = await getCollection('vergangene-termine');
const trainings = (await getCollection('trainings')).sort(
  (a, b) => a.data.start.getTime() - b.data.start.getTime()
);

// Fallback: wenn keine zukuenftigen Events, zeige stattdessen die letzten vergangenen.
const showVergangene = oeffentlich.length === 0 && vergangene.length > 0;
const eventList = showVergangene ? vergangene : oeffentlich;
const eventHeading = showVergangene ? 'Vergangene Termine' : 'Bevorstehende Termine';

// Icon-Slug aus dem SUMMARY raten.
type EventIconName = 'calendar' | 'ship' | 'video' | 'goggles' | 'pool' | 'waves';
function guessIcon(summary: string): EventIconName {
  const s = summary.toLowerCase();
  if (/mare|mont|stammt/.test(s)) return 'pool';
  if (/antauch|see|freiwasser/.test(s)) return 'waves';
  if (/film|kino|video|tour/.test(s)) return 'video';
  if (/boot|messe|schiff/.test(s)) return 'ship';
  if (/apnoe|frei|tauch|training/.test(s)) return 'goggles';
  return 'calendar';
}

// Datum/Uhrzeit auf Deutsch.
const wochentag = new Intl.DateTimeFormat('de-DE', { weekday: 'short' });
const datumLong = new Intl.DateTimeFormat('de-DE', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});
const datumKurz = new Intl.DateTimeFormat('de-DE', {
  day: '2-digit',
  month: '2-digit',
  year: '2-digit',
});
const uhrzeit = new Intl.DateTimeFormat('de-DE', {
  hour: '2-digit',
  minute: '2-digit',
});

function formatBadge(start: Date): string {
  return `${wochentag.format(start)}, ${datumLong.format(start)}`;
}
function formatDatum(start: Date, end?: Date): string {
  const d = datumLong.format(start);
  if (!end || start.toDateString() !== end.toDateString()) return d;
  return `${d}, ${uhrzeit.format(start)}–${uhrzeit.format(end)} Uhr`;
}

function splitDescription(desc: string): { untertitel: string; body: string } {
  const lines = desc
    .split(/\r?\n/)
    .map((l) => l.trim())
    .filter(Boolean);
  if (lines.length === 0) return { untertitel: '', body: '' };
  const first = lines[0];
  if (lines.length === 1 || first.length < 80) {
    return { untertitel: first, body: lines.slice(1).join('\n\n') };
  }
  return { untertitel: '', body: desc };
}
---
<section class="veranstaltungen" id={section.id} style="background: var(--white);">
  <div class="section-title">
    <h2>{section.data.title}</h2>
    {section.data.subtitle && <p>{section.data.subtitle}</p>}
  </div>

  <div class="termin-block">
    <h3 class="block-heading">{eventHeading}</h3>
    {showVergangene && (
      <p class="block-hint">
        Aktuell stehen keine öffentlichen Termine an. Hier ein Rückblick auf die letzten.
      </p>
    )}
    {eventList.length === 0 ? (
      <p class="no-events">Aktuell sind keine öffentlichen Termine eingetragen.</p>
    ) : showVergangene ? (
      <ul class="trainings-list">
        {eventList.map((entry) => (
          <li class="training-row">
            <div class="training-date training-date-past">
              <span class="training-weekday">{wochentag.format(entry.data.start)}</span>
              <span class="training-date-num">{datumKurz.format(entry.data.start)}</span>
            </div>
            <div class="training-info">
              <span class="training-title">{entry.data.summary}</span>
              <span class="training-time">
                {datumLong.format(entry.data.start)}
                {entry.data.location && <span class="training-loc"> · {entry.data.location}</span>}
              </span>
            </div>
          </li>
        ))}
      </ul>
    ) : (
      <div class="features-grid">
        {eventList.map((entry) => {
          const icon = guessIcon(entry.data.summary);
          const { untertitel, body } = splitDescription(entry.data.description);
          return (
            <div class="feature-card fade-in event-card">
              <div class="event-card-header">
                <EventIcon name={icon} />
                <span class="event-badge event-badge-gold">{formatBadge(entry.data.start)}</span>
              </div>
              <h4 class="event-title">{entry.data.summary}</h4>
              {untertitel && <p class="event-sub">{untertitel}</p>}
              {body && <div class="event-description" style="white-space: pre-line;">{body}</div>}
              <div class="event-infos">
                <p><strong>Datum:</strong> {formatDatum(entry.data.start, entry.data.end)}</p>
                {entry.data.location && (
                  <p style="margin-top: 0.5rem;"><strong>Ort:</strong> {entry.data.location}</p>
                )}
              </div>
              {entry.data.url && (
                <a href={entry.data.url} target="_blank" rel="noopener" class="btn btn-primary event-cta">
                  Details in der Vereinsapp
                </a>
              )}
            </div>
          );
        })}
      </div>
    )}
  </div>

  <div class="termin-block">
    <h3 class="block-heading">Nächste Trainings</h3>
    {trainings.length === 0 ? (
      <p class="no-events">Aktuell sind keine Trainings eingetragen.</p>
    ) : (
      <ul class="trainings-list">
        {trainings.map((entry) => (
          <li class="training-row">
            <div class="training-date">
              <span class="training-weekday">{wochentag.format(entry.data.start)}</span>
              <span class="training-date-num">{datumKurz.format(entry.data.start)}</span>
            </div>
            <div class="training-info">
              <span class="training-title">{entry.data.summary}</span>
              <span class="training-time">
                {uhrzeit.format(entry.data.start)}
                {entry.data.end && `–${uhrzeit.format(entry.data.end)}`} Uhr
                {entry.data.location && <span class="training-loc"> · {entry.data.location}</span>}
              </span>
            </div>
          </li>
        ))}
      </ul>
    )}
  </div>
</section>

<style>
  .termin-block {
    max-width: 1100px;
    margin: 0 auto 3rem;
  }
  .termin-block:last-child {
    margin-bottom: 0;
  }
  .block-heading {
    color: var(--blue);
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    padding-left: 0.5rem;
    border-left: 4px solid var(--gold);
  }

  /* Oeffentliche Termine: Cards */
  .event-card {
    text-align: left;
    border-top: 4px solid var(--gold);
  }
  .event-card-header {
    display: flex;
    justify-content: space-between;
    align-items: start;
    margin-bottom: 1rem;
  }
  .event-title {
    color: var(--blue);
    margin-bottom: 0.5rem;
  }
  .event-sub {
    color: var(--gold);
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }
  .event-description {
    color: var(--gray);
    font-size: 0.95rem;
    margin-bottom: 1rem;
  }
  .event-description :global(p) {
    margin: 0 0 0.5rem;
  }
  .event-infos {
    background: var(--gray-light);
    padding: 1rem;
    border-radius: 10px;
    font-size: 0.9rem;
  }
  .event-cta {
    width: 100%;
    justify-content: center;
    margin-top: 1rem;
  }
  .event-badge {
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
  }
  .event-badge-gold {
    background: var(--gold);
    color: var(--blue-dark);
  }
  .event-badge-grey {
    background: var(--gray);
    color: var(--white);
  }
  .training-date-past {
    background: var(--gray) !important;
  }
  .block-hint {
    color: var(--gray);
    font-size: 0.95rem;
    margin: 0 0 1.25rem;
    padding-left: 0.5rem;
  }

  /* Trainings: kompakte Liste */
  .trainings-list {
    list-style: none;
    padding: 0;
    margin: 0;
    background: var(--gray-light);
    border-radius: 12px;
    overflow: hidden;
  }
  .training-row {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid rgba(0, 79, 158, 0.08);
    align-items: center;
  }
  .training-row:last-child {
    border-bottom: none;
  }
  .training-date {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: var(--blue);
    color: var(--white);
    padding: 0.5rem;
    border-radius: 8px;
    box-shadow: 0 2px 6px rgba(0, 79, 158, 0.2);
  }
  .training-weekday {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--gold);
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .training-date-num {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--white);
    margin-top: 0.1rem;
  }
  .training-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .training-title {
    color: var(--blue);
    font-weight: 600;
  }
  .training-time {
    color: var(--gray);
    font-size: 0.9rem;
  }
  .training-loc {
    color: var(--gray);
  }

  .no-events {
    text-align: center;
    color: var(--gray);
    font-size: 1rem;
    padding: 2rem 1rem;
    background: var(--gray-light);
    border-radius: 10px;
  }
</style>
