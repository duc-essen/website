---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  section: CollectionEntry<'sections'>;
  isStandalone?: boolean;
}
const { section } = Astro.props;

const zukuenftige = (await getCollection('veranstaltungen')).sort(
  (a, b) => a.data.start.getTime() - b.data.start.getTime()
);
// Vergangene Termine kommen aus dem Loader bereits absteigend sortiert (neueste zuerst).
const vergangene = await getCollection('vergangene-termine');
const trainings = (await getCollection('trainings')).sort(
  (a, b) => a.data.start.getTime() - b.data.start.getTime()
);

// Immer maximal 6 Termine zeigen: zuerst zukuenftige, dann mit vergangenen
// auf 6 auffuellen.
const TERMINE_LIMIT = 6;
const termine = [
  ...zukuenftige.slice(0, TERMINE_LIMIT).map((entry) => ({ entry, isPast: false })),
];
const fillCount = TERMINE_LIMIT - termine.length;
if (fillCount > 0) {
  for (const entry of vergangene.slice(0, fillCount)) {
    termine.push({ entry, isPast: true });
  }
}

// Datum/Uhrzeit auf Deutsch.
const wochentag = new Intl.DateTimeFormat('de-DE', { weekday: 'short' });
const datumLong = new Intl.DateTimeFormat('de-DE', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});
const datumKurz = new Intl.DateTimeFormat('de-DE', {
  day: '2-digit',
  month: '2-digit',
  year: '2-digit',
});
const uhrzeit = new Intl.DateTimeFormat('de-DE', {
  hour: '2-digit',
  minute: '2-digit',
});

function formatBadge(start: Date): string {
  return `${wochentag.format(start)}, ${datumLong.format(start)}`;
}
function formatDatum(start: Date, end?: Date): string {
  const d = datumLong.format(start);
  if (!end || start.toDateString() !== end.toDateString()) return d;
  return `${d}, ${uhrzeit.format(start)}–${uhrzeit.format(end)} Uhr`;
}

function splitDescription(desc: string): { untertitel: string; body: string } {
  const lines = desc
    .split(/\r?\n/)
    .map((l) => l.trim())
    .filter(Boolean);
  if (lines.length === 0) return { untertitel: '', body: '' };
  const first = lines[0];
  if (lines.length === 1 || first.length < 80) {
    return { untertitel: first, body: lines.slice(1).join('\n\n') };
  }
  return { untertitel: '', body: desc };
}
---
<section class="veranstaltungen" id={section.id}>
  <div class="section-title">
    <h2>{section.data.title}</h2>
    {section.data.subtitle && <p>{section.data.subtitle}</p>}
  </div>

  <div class="termin-block">
    {termine.length === 0 ? (
      <p class="no-events">Aktuell sind keine öffentlichen Termine eingetragen.</p>
    ) : (
      <ul class="trainings-list">
        {termine.map(({ entry, isPast }) => (
          <li class={`training-row${isPast ? ' training-row-past' : ''}`}>
            <div class={`training-date${isPast ? ' training-date-past' : ''}`}>
              <span class="training-weekday">{wochentag.format(entry.data.start)}</span>
              <span class="training-date-num">{datumKurz.format(entry.data.start)}</span>
            </div>
            <div class="training-info">
              <span class="training-title">
                {entry.data.summary}
                {isPast && <span class="badge-past"> vergangen</span>}
              </span>
              <span class="training-time">
                {datumLong.format(entry.data.start)}
                {entry.data.location && <span class="training-loc"> · {entry.data.location}</span>}
              </span>
            </div>
          </li>
        ))}
      </ul>
    )}
  </div>

  <div class="termin-block">
    <h3 class="block-heading">Nächste Trainings</h3>
    {trainings.length === 0 ? (
      <p class="no-events">Aktuell sind keine Trainings eingetragen.</p>
    ) : (
      <ul class="trainings-list">
        {trainings.map((entry) => (
          <li class="training-row">
            <div class="training-date">
              <span class="training-weekday">{wochentag.format(entry.data.start)}</span>
              <span class="training-date-num">{datumKurz.format(entry.data.start)}</span>
            </div>
            <div class="training-info">
              <span class="training-title">{entry.data.summary}</span>
              <span class="training-time">
                {uhrzeit.format(entry.data.start)}
                {entry.data.end && `–${uhrzeit.format(entry.data.end)}`} Uhr
                {entry.data.location && <span class="training-loc"> · {entry.data.location}</span>}
              </span>
            </div>
          </li>
        ))}
      </ul>
    )}
  </div>
</section>

<style>
  .veranstaltungen {
    background: var(--white);
  }
  .termin-block {
    max-width: 1100px;
    margin: 0 auto 3rem;
  }
  .termin-block:last-child {
    margin-bottom: 0;
  }
  .block-heading {
    color: var(--blue);
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    padding-left: 0.5rem;
    border-left: 4px solid var(--gold);
  }

  /* Oeffentliche Termine: Cards */
  .event-card {
    text-align: left;
    border-top: 4px solid var(--gold);
  }
  .event-card-header {
    display: flex;
    justify-content: space-between;
    align-items: start;
    margin-bottom: 1rem;
  }
  .event-title {
    color: var(--blue);
    margin-bottom: 0.5rem;
  }
  .event-sub {
    color: var(--gold);
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }
  .event-description {
    color: var(--gray);
    font-size: 0.95rem;
    margin-bottom: 1rem;
  }
  .event-description :global(p) {
    margin: 0 0 0.5rem;
  }
  .event-infos {
    background: var(--gray-light);
    padding: 1rem;
    border-radius: 10px;
    font-size: 0.9rem;
  }
  .event-cta {
    width: 100%;
    justify-content: center;
    margin-top: 1rem;
  }
  .event-badge {
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
  }
  .event-badge-gold {
    background: var(--gold);
    color: var(--blue-dark);
  }
  .event-badge-grey {
    background: var(--gray);
    color: var(--white);
  }
  .training-date-past {
    background: var(--gray) !important;
  }
  .training-row-past .training-title,
  .training-row-past .training-time {
    color: var(--gray);
  }
  .badge-past {
    display: inline-block;
    background: var(--gray);
    color: var(--white);
    padding: 0.1rem 0.5rem;
    margin-left: 0.5rem;
    border-radius: 10px;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    vertical-align: middle;
  }
  .block-hint {
    color: var(--gray);
    font-size: 0.95rem;
    margin: 0 0 1.25rem;
    padding-left: 0.5rem;
  }

  /* Trainings: kompakte Liste */
  .trainings-list {
    list-style: none;
    padding: 0;
    margin: 0;
    background: var(--gray-light);
    border-radius: 12px;
    overflow: hidden;
  }
  .training-row {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid rgba(0, 79, 158, 0.08);
    align-items: center;
  }
  .training-row:last-child {
    border-bottom: none;
  }
  .training-date {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: var(--blue);
    color: var(--white);
    padding: 0.5rem;
    border-radius: 8px;
    box-shadow: 0 2px 6px rgba(0, 79, 158, 0.2);
  }
  .training-weekday {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--gold);
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .training-date-num {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--white);
    margin-top: 0.1rem;
  }
  .training-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .training-title {
    color: var(--blue);
    font-weight: 600;
  }
  .training-time {
    color: var(--gray);
    font-size: 0.9rem;
  }
  .training-loc {
    color: var(--gray);
  }

  .no-events {
    text-align: center;
    color: var(--gray);
    font-size: 1rem;
    padding: 2rem 1rem;
    background: var(--gray-light);
    border-radius: 10px;
  }
</style>
