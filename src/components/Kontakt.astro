---
import type { CollectionEntry } from 'astro:content';
import KontaktIcon from './icons/KontaktIcon.astro';

interface Props {
  section: CollectionEntry<'sections'>;
  isStandalone?: boolean;
}
const { section } = Astro.props;
const k = section.data.kontakt!;
---
<section class="contact" id={section.id}>
  <div class="section-title">
    <h2>{section.data.title}</h2>
    {section.data.subtitle && <p>{section.data.subtitle}</p>}
  </div>
  <div class="contact-grid">
    <div class="contact-info fade-in">
      <h3>So erreichst du uns</h3>
      {k.items.map((item) => (
        <div class="contact-item">
          <div class="contact-item-icon"><KontaktIcon name={item.icon} /></div>
          <div class="contact-item-text">
            <h4>{item.label}</h4>
            {item.label === 'E-Mail' ? (
              <p>
                <a href={`mailto:${item.text.trim()}`} style="color: var(--gold); text-decoration: none; font-weight: 600;">
                  {item.text.trim()}
                </a>
              </p>
            ) : (
              <p style="white-space: pre-line;">{item.text}</p>
            )}
          </div>
        </div>
      ))}
    </div>
    <div class="contact-form fade-in" style="padding: 0; overflow: hidden;">
      <iframe
        data-name="vereinsplaner"
        data-src={k.formEmbedUrl}
        style="width: 100%; min-height: 1000px; border: none;"
        loading="lazy"
        title="Anmeldeformular für Probetraining beim DUC Essen"
      />
    </div>
  </div>
</section>
