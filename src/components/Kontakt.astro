---
import type { CollectionEntry } from 'astro:content';
import Icon from './Icon.astro';

interface Props {
  section: CollectionEntry<'sections'>;
  isStandalone?: boolean;
}
const { section } = Astro.props;
if (!section.data.kontakt) {
  throw new Error(
    `Section "${section.id}" wird mit der Kontakt-Komponente gerendert, ` +
      `hat aber keinen "kontakt"-Frontmatter-Block in src/content/sections/${section.id}.md.`
  );
}
const k = section.data.kontakt;
---
<section class="contact" id={section.id}>
  <div class="section-title">
    <h2>{section.data.title}</h2>
    {section.data.subtitle && <p>{section.data.subtitle}</p>}
  </div>
  <div class="contact-grid">
    <div class="contact-info fade-in">
      <h3>So erreichst du uns</h3>
      {k.items.map((item) => (
        <div class="contact-item">
          <div class="contact-item-icon"><Icon catalog="kontakt" name={item.icon} /></div>
          <div class="contact-item-text">
            <h4>{item.label}</h4>
            {item.label === 'E-Mail' ? (
              <p>
                <a href={`mailto:${item.text.trim()}`} class="contact-email">{item.text.trim()}</a>
              </p>
            ) : (
              <p class="contact-multiline">{item.text}</p>
            )}
          </div>
        </div>
      ))}
    </div>
    <div class="contact-form fade-in">
      <iframe
        data-name="vereinsplaner"
        data-src={k.formEmbedUrl}
        class="contact-iframe"
        loading="lazy"
        title="Anmeldeformular für Probetraining beim DUC Essen"
      />
    </div>
  </div>
</section>

<style>
  .contact-email {
    color: var(--gold);
    text-decoration: none;
    font-weight: 600;
  }
  .contact-multiline {
    white-space: pre-line;
  }
  .contact-form {
    padding: 0;
    overflow: hidden;
  }
  .contact-iframe {
    width: 100%;
    min-height: 1000px;
    border: none;
  }
</style>
