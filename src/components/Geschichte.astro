---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import TimelineIcon from './icons/TimelineIcon.astro';
import CtaButton from './CtaButton.astro';

interface Props {
  section: CollectionEntry<'sections'>;
  isStandalone?: boolean;
}
const { section, isStandalone = false } = Astro.props;

const entries = (await getCollection('geschichte')).sort(
  (a, b) => a.data.order - b.data.order
);
const rendered = await Promise.all(
  entries.map(async (entry) => ({ entry, Content: (await render(entry)).Content }))
);
---
<section class="geschichte" id={section.id}>
  <div class="section-title">
    <h2>{section.data.title}</h2>
    {section.data.subtitle && <p>{section.data.subtitle}</p>}
  </div>
  <div class="timeline">
    {rendered.map(({ entry, Content }) => (
      <div class="timeline-item fade-in">
        <div class={`timeline-card${entry.data.highlight ? ' timeline-highlight' : ''}`}>
          <div class="timeline-header">
            <span class="timeline-icon"><TimelineIcon name={entry.data.icon} /></span>
            <span class="timeline-year">{entry.data.jahr}</span>
          </div>
          <div class="timeline-title">{entry.data.titel}</div>
          <div class="timeline-text"><Content /></div>
        </div>
      </div>
    ))}
  </div>
  {section.data.cta && (
    <div style="text-align: center; margin-top: 2rem;">
      <CtaButton cta={section.data.cta} isStandalone={isStandalone} />
    </div>
  )}
</section>
