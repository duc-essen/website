---
import { getCollection } from 'astro:content';
import { pathTo } from '../utils/url';
import verein from '../data/verein.json';

const vorstand = (await getCollection('vorstand')).sort(
  (a, b) => a.data.order - b.data.order
);
const sections = (await getCollection('sections'))
  .filter((s) => s.data.navLabel)
  .sort((a, b) => a.data.order - b.data.order);
---
<footer>
  <div class="footer-content">
    <div class="footer-section">
      <h4>{verein.shortName}</h4>
      <p>{verein.name}<br>{verein.traegervereinHinweis}</p>
      <p class="footer-postanschrift"><strong>Postanschrift:</strong><br>{verein.anschrift.postfach}<br>{verein.anschrift.plzOrt}</p>
    </div>
    <div class="footer-section">
      <h4>Vorstand</h4>
      {vorstand.map((person) => (
        <p>{person.data.rolle}: {person.data.name}</p>
      ))}
    </div>
    <div class="footer-section">
      <h4>Quick Links</h4>
      <a href={pathTo('')}>Start</a>
      {sections.map((s) => (
        <a href={pathTo(s.id)}>{s.data.navLabel}</a>
      ))}
    </div>
    <div class="footer-section">
      <h4>Recht</h4>
      <p>{verein.name}</p>
      <p>Registergericht: {verein.registergericht}</p>
      <p>Registernummer: {verein.registernummer}</p>
      <a href={pathTo('impressum')} class="footer-recht-link footer-recht-first">Impressum</a>
      <a href={pathTo('datenschutz')} class="footer-recht-link">Datenschutz</a>
      <a
        href="#"
        onclick="event.preventDefault(); window.klaro && window.klaro.show();"
        class="footer-recht-link"
      >Cookie-Einstellungen</a>
    </div>
  </div>
  <div class="footer-bottom">
    <p>&copy; <span id="currentYear"></span> Deutscher Unterwasserclub Essen e.V. - Alle Rechte vorbehalten</p>
  </div>
</footer>

<style>
  .footer-postanschrift {
    margin-top: 1rem;
  }
  .footer-recht-link {
    display: inline-block;
  }
  .footer-recht-first {
    margin-top: 1rem;
  }
</style>
