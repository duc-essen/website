---
import { getCollection } from 'astro:content';
import { pathTo } from '../utils/url';

const vorstand = (await getCollection('vorstand')).sort(
  (a, b) => a.data.order - b.data.order
);
const sections = (await getCollection('sections'))
  .filter((s) => s.data.navLabel)
  .sort((a, b) => a.data.order - b.data.order);
---
<footer>
  <div class="footer-content">
    <div class="footer-section">
      <h4>DUC Essen</h4>
      <p>Deutscher Unterwasserclub Essen e.V.<br>Trägerverein des Landesleistungsstützpunktes NRW für Freitauchen</p>
      <p style="margin-top: 1rem;"><strong>Postanschrift:</strong><br>Postfach 34 01 51<br>45073 Essen</p>
    </div>
    <div class="footer-section">
      <h4>Vorstand</h4>
      {vorstand.map((person) => (
        <p>{person.data.rolle}: {person.data.name}</p>
      ))}
    </div>
    <div class="footer-section">
      <h4>Quick Links</h4>
      <a href={pathTo('')}>Start</a>
      {sections.map((s) => (
        <a href={pathTo(s.id)}>{s.data.navLabel}</a>
      ))}
    </div>
    <div class="footer-section">
      <h4>Recht</h4>
      <p>Deutscher Unterwasserclub Essen e.V.</p>
      <p>Registergericht: Amtsgericht Essen</p>
      <p>Registernummer: VR 1507</p>
      <a href={pathTo('impressum')} style="margin-top: 1rem; display: inline-block;">Impressum</a>
      <a href={pathTo('datenschutz')} style="display: inline-block;">Datenschutz</a>
      <a
        href="#"
        onclick="event.preventDefault(); window.klaro && window.klaro.show();"
        style="display: inline-block;"
      >Cookie-Einstellungen</a>
    </div>
  </div>
  <div class="footer-bottom">
    <p>&copy; <span id="currentYear"></span> Deutscher Unterwasserclub Essen e.V. - Alle Rechte vorbehalten</p>
  </div>
</footer>
