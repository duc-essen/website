---
import type { TimelineIconName } from '../../types/icons';
interface Props {
  name: TimelineIconName;
}
const { name } = Astro.props;
---
{name === 'diver' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="#004F9E" stroke-width="2"><circle cx="12" cy="5" r="3"/><path d="M5 22c0-5 3-7 7-7s7 2 7 7"/><path d="M5 12h14" stroke="#FFD400"/></svg>
)}
{name === 'document' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="#004F9E" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M8 13h8" stroke="#FFD400"/><path d="M8 17h8" stroke="#FFD400"/></svg>
)}
{name === 'trophy' && (
  <svg viewBox="0 0 24 24" fill="#FFD400" stroke="#004F9E" stroke-width="1.5"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5C6 4 6 5.5 6 5.5V9zm12 0h1.5a2.5 2.5 0 0 0 0-5C18 4 18 5.5 18 5.5V9z"/><path d="M4 22h16v-4H4z"/><path d="M6 18V9h12v9"/><path d="M12 4v5"/></svg>
)}
{name === 'compass' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="#004F9E" stroke-width="2"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4" fill="#FFD400" stroke="#FFD400"/><path d="M12 3v2M12 19v2M3 12h2M19 12h2"/></svg>
)}
{name === 'star' && (
  <svg viewBox="0 0 24 24" fill="#FFD400" stroke="#004F9E" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
)}
{name === 'medal' && (
  <svg viewBox="0 0 24 24" fill="#FFD400" stroke="#004F9E" stroke-width="1.5"><circle cx="12" cy="8" r="6"/><path d="M12 14v8"/><path d="M8 22h8"/><path d="M9 6l3 3 3-3" stroke="#004F9E" fill="none" stroke-width="2"/></svg>
)}
