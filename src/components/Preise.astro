---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import PriceIcon from './icons/PriceIcon.astro';
import CtaButton from './CtaButton.astro';

interface Props {
  section: CollectionEntry<'sections'>;
  isStandalone?: boolean;
}
const { section, isStandalone = false } = Astro.props;

const preise = (await getCollection('preise')).sort((a, b) => a.data.order - b.data.order);
---
<section class="preise" id={section.id} style="background: var(--gray-light);">
  <div class="section-title">
    <h2>{section.data.title}</h2>
    {section.data.subtitle && <p>{section.data.subtitle}</p>}
  </div>
  <div style="max-width: 1000px; margin: 0 auto;">
    <div class="features-grid" style="margin-bottom: 3rem;">
      {preise.map((p) => (
        <div class="feature-card fade-in" style="text-align: center;">
          <div style="margin-bottom: 1rem;"><PriceIcon name={p.data.icon} /></div>
          <h3 style="color: var(--blue);">{p.data.gruppe}</h3>
          <p style="font-size: 2.5rem; font-weight: 800; color: var(--blue); margin: 1rem 0;">{p.data.preis_monat}</p>
          <p style="color: var(--gray);">pro Monat</p>
          <p style="color: var(--gray); font-size: 0.9rem; margin-top: 0.5rem;">({p.data.preis_quartal} / Quartal)</p>
        </div>
      ))}
    </div>
    {section.data.cta && (
      <div style="text-align: center; margin-top: 2rem;">
        <CtaButton cta={section.data.cta} isStandalone={isStandalone} />
      </div>
    )}
  </div>
</section>
