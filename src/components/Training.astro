---
import type { CollectionEntry } from 'astro:content';
import { assetUrl } from '../utils/url';
import CtaButton from './CtaButton.astro';

interface Props {
  section: CollectionEntry<'sections'>;
  isStandalone?: boolean;
}
const { section, isStandalone = false } = Astro.props;

const t = section.data.training!;
---
<section class="training" id={section.id}>
  <div class="section-title">
    <h2>{section.data.title}</h2>
    {section.data.subtitle && <p>{section.data.subtitle}</p>}
  </div>
  <div class="training-content">
    <div class="training-info fade-in">
      <h3>{t.ort}</h3>
      <p style="white-space: pre-line;">{t.beschreibung}</p>
      <div class="training-schedule">
        {t.schedule.map((s) => (
          <div class="schedule-item">
            <span class="schedule-day">{s.tag}</span>
            <span class="schedule-time">{s.zeit}</span>
          </div>
        ))}
      </div>
      {section.data.cta && (
        <div style="margin-top: 2rem;">
          <CtaButton cta={section.data.cta} isStandalone={isStandalone} />
        </div>
      )}
    </div>
    <div class="training-visual fade-in">
      <div style="display: flex; flex-direction: column; gap: 1rem;">
        {t.bilder.map((bild) => (
          <img
            src={assetUrl(bild.url)}
            alt={bild.alt}
            loading="lazy"
            style="width: 100%; border-radius: 15px; object-fit: cover; height: 180px; box-shadow: 0 10px 30px rgba(0,79,158,0.2);"
          />
        ))}
      </div>
    </div>
  </div>
  <div style="width: 100vw; margin-left: calc(-50vw + 50%); margin-top: 2rem;">
    <iframe
      data-name="google-maps"
      data-src={t.mapEmbedUrl}
      style="width: 100%; height: 400px; border: none;"
      allowfullscreen=""
      loading="lazy"
      title={`Google Maps Standort ${t.ort}`}
    />
  </div>
</section>
