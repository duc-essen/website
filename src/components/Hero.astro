---
import DucLogo from './DucLogo.astro';
import CtaButton from './CtaButton.astro';
import hero from '../data/hero.json';

interface Props {
  isStandalone?: boolean;
}
const { isStandalone = false } = Astro.props;
---
<section class="hero" id="home">
  <div class="hero-content">
    <div class="logo-container">
      <div class="logo-bubbles">
        <span></span><span></span><span></span><span></span><span></span>
        <span></span><span></span><span></span><span></span><span></span>
      </div>
      <DucLogo class="hero-logo" />
    </div>
    <h1>{hero.titleLine1}<span>{hero.titleLine2}</span></h1>
    <p>{hero.tagline}</p>
    <div class="cta-buttons">
      <CtaButton cta={hero.ctaPrimary} variant="primary" isStandalone={isStandalone} />
      <CtaButton cta={hero.ctaSecondary} variant="secondary" isStandalone={isStandalone} />
    </div>
  </div>
  <div class="scroll-indicator">
    <svg viewBox="0 0 24 24"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"/></svg>
  </div>
</section>
